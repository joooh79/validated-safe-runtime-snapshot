# Local MCP server for VS Code Copilot / Codex
PORT=10001
TRUST_PROXY_AUTH=false

# Real Airtable execution
AIRTABLE_MODE=real
AIRTABLE_BASE_ID=app_your_base_id
AIRTABLE_API_TOKEN=pat_your_personal_access_token

# Optional
# AIRTABLE_API_BASE_URL=https://api.airtable.com/v0

# Only needed when a signed proxy sits in front of this Node server
# PROXY_SHARED_SECRET=replace_me
